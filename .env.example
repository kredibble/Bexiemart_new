# Database (Neon PostgreSQL)
# Get your connection string from https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/bexiemart?sslmode=require"

# Better Auth API URL
# In development, this is your Expo dev server URL
EXPO_PUBLIC_API_URL="http://localhost:8081"

# Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (Web application type)
# 2. Add authorized redirect URI: http://localhost:8081/api/auth/callback/google
EXPO_PUBLIC_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
